# LazyEASM Environment Variables
# Copy this file to .env and fill in your values

# SecurityTrails API Key (for subdomain discovery)
# Get your key at: https://securitytrails.com/
SECURITYTRAILS_API_KEY=

# Vulners API Key (for CVE matching)
# Get your key at: https://vulners.com/
VULNERS_API_KEY=

# Google Gemini API Key (for AI recommendations)
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# Discord Webhook URL (for notifications)
# Format: https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN
# Create webhook in your Discord server: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=

# Discord User ID (optional - user to ping on alerts)
# Find your ID: Enable Developer Mode in Discord > Right-click your name > Copy ID
DISCORD_USER_ID=

# Flask Secret Key (for session encryption)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# JWT Secret (for token signing)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=